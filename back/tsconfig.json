{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "strict": true,
        "skipLibCheck": true,
        "verbatimModuleSyntax": true,
        "noEmit": true
    },
    "include": ["src"]
}
