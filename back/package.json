{
    "name": "@fc/back",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "predev": "pnpm --filter @fc/shared build",
        "dev": "nest start --watch",
        "dev:prod": "dotenv -e .env.prod -- nest start --watch",
        "build": "nest build",
        "start": "node dist/main",
        "start:prod": "dotenv -e .env.prod -- node dist/main",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "dotenv -e .env.prod -- prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:studio:prod": "dotenv -e .env.prod -- prisma studio"
    },
    "dependencies": {
        "@fc/shared": "workspace:*",
        "@nestjs/common": "^10",
        "@nestjs/core": "^10",
        "@nestjs/platform-express": "^10",
        "@prisma/client": "^6.9.0",
        "nestjs-zod": "^5.3.0",
        "reflect-metadata": "^0.2.2",
        "zod": "^3.25.71"
    },
    "devDependencies": {
        "@nestjs/cli": "^10",
        "@nestjs/schematics": "^10",
        "@swc/core": "^1.15.30",
        "@types/express": "^5.0.6",
        "@types/node": "^22.15.32",
        "dotenv-cli": "^11.0.0",
        "prisma": "^6.9.0",
        "typescript": "~5.8.3"
    }
}
