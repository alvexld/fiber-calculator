generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Meal {
  id              String           @id
  date            String
  name            String
  totalFiberGrams Float
  createdAt       DateTime         @default(now())
  ingredients     MealIngredient[]
}

model MealIngredient {
  id           String @id
  mealId       String
  ingredientId String
  name         String
  unit         String
  quantity     Float
  fiberPerUnit Float
  fiberGrams   Float
  meal         Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
}
