{
    "name": "@fc/back",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "prisma migrate deploy && prisma db seed && nest start --watch",
        "typecheck": "prisma generate && tsc --noEmit",
        "lint": "oxlint .",
        "knip": "knip",
        "format": "oxfmt .",
        "format:check": "oxfmt --check .",
        "dev:prod": "dotenv -e .env.prod -- nest start --watch",
        "build": "prisma generate && nest build",
        "start": "prisma migrate deploy && node dist/src/main",
        "start:prod": "dotenv -e .env.prod -- node dist/src/main",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "dotenv -e .env.prod -- prisma migrate deploy",
        "db:seed": "prisma db seed",
        "db:seed:prod": "dotenv -e .env.prod -- prisma db seed",
        "db:studio": "prisma studio",
        "db:check": "prisma migrate deploy && prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --exit-code",
        "db:studio:prod": "dotenv -e .env.prod -- prisma studio"
    },
    "dependencies": {
        "@fc/shared": "workspace:*",
        "@nestjs/common": "^11.1.19",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11",
        "@nestjs/throttler": "^6.5.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.4.2",
        "helmet": "^8.1.0",
        "nestjs-zod": "^5.3.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@nestjs/cli": "^11",
        "@nestjs/schematics": "^11",
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.30",
        "@types/bcryptjs": "^3.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/node": "^22.13.0",
        "@types/passport": "^1.0.17",
        "@types/passport-jwt": "^4.0.1",
        "@types/pg": "^8.20.0",
        "dotenv-cli": "^11.0.0",
        "knip": "^6.6.3",
        "oxfmt": "^0.46.0",
        "oxlint": "^1.61.0",
        "prisma": "^7.8.0",
        "rxjs": "^7.8.2",
        "tsx": "^4.21.0",
        "typescript": "~5.9.3"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    }
}
