## Views

Each view folder contains exactly two main components:

- `<view>.view.tsx` — smart component: fetches data, handles errors, passes everything down
- `<view>.ui.tsx` — dumb component: renders the full layout of the view

```tsx
// ✅ homescreen.view.tsx
export Homescreen = () => {
    const { data, isLoading, error } = useQuery({
        queryKey: ["users"],
        queryFn: fetchUsers,
    });
    if (isLoading) return <LoadingIndicator />;
    if (error) return <ErrorScreen error={error} />;
    return <HomescreenUI users={data} />;
}

// ✅ homescreen.ui.tsx
export HomescreenUI = ({ users }: HomescreenUIProps) => {
    return (
        <main className="main">
            <UserList users={users} />
        </main>
    );
}
```

